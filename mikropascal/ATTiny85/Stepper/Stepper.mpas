PROGRAM Stepper;

CONST
  FullStep : ARRAY [0 .. 3] OF byte = ($09, $0C, $06, $03);
  HalfStep : ARRAY [0 .. 7] OF byte = ($08, $0C, $04, $06, $02, $03, $01, $09);

VAR
  Dir  : SBIT AT PINB.B5;
  Step : SBIT AT PINB.B4;

  OutputIndex : Byte;
  OldState    : Boolean;
  NewState    : Boolean;

BEGIN
  PORTB       := $00;
  DDRB        := $0F;
  OutputIndex := 0;
  PORTB       := FullStep[OutputIndex];
  OldState    := Step;

  REPEAT
    NewState := Step;

    IF NewState AND NOT OldState THEN
      BEGIN
        IF Dir THEN
          OutputIndex := (OutputIndex + 1) AND $03
        ELSE
          OutputIndex := (OutputIndex - 1) AND $03;

        PORTB := FullStep[OutputIndex];
      END;

    OldState := NewState;
  UNTIL False;
END.
